#!/bin/bash

#===[ Constants ]===
PROJECT_NAME="DnsProxy"
BASE_DIR="/usr/local/bin/DnsProxy"
CONFIG_DIR="/etc/coredns/conf.d"
HOSTS_DIR="/etc/unblocker"

#===[ Colors ]===
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
RESET='\033[0m'
BOLD='\033[1m'

#===[ CLI Mode Parameter Handling ]===
if [ "$#" -gt 0 ]; then
    case "$1" in
        "add")
            if [ -z "${2:-}" ] || [ -z "${3:-}" ]; then
                echo -e "${RED}❌ Usage: dnsproxy add <service_name> <auto|manual>${RESET}"
                exit 1
            fi
            "$BASE_DIR/AddDomain.sh" "$2" "$3"
            exit 0
            ;;
        "remove")
            if [ -z "${2:-}" ]; then
                echo -e "${RED}❌ Usage: dnsproxy remove <service_name>${RESET}"
                exit 1
            fi
            conf_file="$CONFIG_DIR/$2.conf"
            hosts_file="$HOSTS_DIR/$2.hosts"
            if [ -f "$conf_file" ] || [ -f "$hosts_file" ]; then
                sudo rm -f "$conf_file" "$hosts_file"
                sudo systemctl restart coredns
                echo -e "${GREEN}✅ Successfully removed '$2'.${RESET}"
            else
                echo -e "${RED}❌ Service '$2' not found.${RESET}"
            fi
            exit 0
            ;;
        *)
            echo -e "${YELLOW}Unknown command. Use 'dnsproxy' for the interactive dashboard.${RESET}"
            exit 1
            ;;
        esac
fi

#===[ Helpers ]===
function clear_and_header() {
    clear
    echo -e "${CYAN}╔══════════════════════════════════════════════════════╗"
    echo -e "║             🌐  DNS-SNI PROXY DASHBOARD              ║"
    echo -e "╚══════════════════════════════════════════════════════╝${RESET}"
    echo
}

function service_status() {
    local vps_ip
    vps_ip=$(cat /etc/dnsproxy/vps_ip.txt 2>/dev/null || curl -s https://api.ipify.org || echo "Unknown")

    local dns_state="🔴 Stopped"
    local nginx_state="🔴 Stopped"
    systemctl is-active --quiet coredns && dns_state="🟢 Running"
    systemctl is-active --quiet nginx && nginx_state="🟢 Running"

    local active_services=0
    local total_domains=0
    if [ -d "$CONFIG_DIR" ]; then
        for file in "$CONFIG_DIR"/*.conf; do
            if [ -e "$file" ]; then
                ((active_services++))
                local sname=$(basename "$file" .conf)
                local hfile="$HOSTS_DIR/${sname}.hosts"
                if [ -f "$hfile" ]; then
                    local dcount
                    dcount=$(wc -l < "$hfile")
                    total_domains=$((total_domains + dcount))
                fi
            fi
        done
    fi

    echo -e "${CYAN}┌──────────────────────────────────────────────────────┐"
    echo -e "  ${BOLD}VPS Public IP${RESET}  :  ${YELLOW}${vps_ip}${RESET}"
    echo -e "  ${BOLD}CoreDNS State${RESET}  :  ${dns_state}"
    echo -e "  ${BOLD}NGINX State${RESET}    :  ${nginx_state}"
    echo -e "  ${BOLD}Active Proxies${RESET} :  ${GREEN}${active_services} services${RESET} (${CYAN}${total_domains} domains${RESET})"
    echo -e "${CYAN}└──────────────────────────────────────────────────────┘${RESET}"
    echo
}

function select_active_service() {
    local services=()
    local count=0
    
    for file in "$CONFIG_DIR"/*.conf; do
        if [ -e "$file" ]; then
            local sname
            sname=$(basename "$file" .conf)
            services+=("$sname")
            ((count++))
        fi
    done
    
    if [ "$count" -eq 0 ]; then
        echo -e "${YELLOW}⚠️  No active services found.${RESET}"
        return 1
    fi
    
    echo -e "${CYAN}Select a service from the list below:${RESET}"
    for i in "${!services[@]}"; do
        echo -e "  ${CYAN}[$((i+1))]${RESET} ${services[$i]}"
    done
    echo -e "  ${CYAN}[$((count+1))]${RESET} 🔙 Back"
    echo
    
    while true; do
        read -n 2 -p "Enter number: " sel
        sel=$(echo "$sel" | xargs)
        if [[ "$sel" =~ ^[0-9]+$ ]] && [ "$sel" -ge 1 ] && [ "$sel" -le "$((count+1))" ]; then
            if [ "$sel" -eq "$((count+1))" ]; then
                return 1
            fi
            selected_service="${services[$((sel-1))]}"
            return 0
        else
            echo -e "\n${RED}❌ Invalid selection. Try again.${RESET}"
        fi
    done
}

function manage_installation() {
    clear_and_header
    if [ -f "/usr/local/bin/coredns" ]; then
        echo -e "${RED}╔══════════════════════════════════════════════════════╗"
        echo -e "║  ⚠️  WARNING: You are about to UNINSTALL DnsProxy.    ║"
        echo -e "║  This will completely erase your configurations!     ║"
        echo -e "╚══════════════════════════════════════════════════════╝${RESET}\n"
        read -n 1 -s -p "Are you sure? Press [y] to Uninstall, any other key to Cancel: " confirm
        if [[ "$confirm" =~ ^[Yy]$ ]]; then
            echo -e "\n"
            "$BASE_DIR/Uninstall.sh"
        else
            echo -e "\n\n${YELLOW}⛔ Uninstallation cancelled.${RESET}"
            sleep 1.5
        fi
    else
        echo -e "${GREEN}╔══════════════════════════════════════════════════════╗"
        echo -e "║  📥  You are about to INSTALL DnsProxy.              ║"
        echo -e "║  This will configure Nginx streams and CoreDNS.      ║"
        echo -e "╚══════════════════════════════════════════════════════╝${RESET}\n"
        read -n 1 -s -p "Are you sure? Press [y] to Install, any other key to Cancel: " confirm
        if [[ "$confirm" =~ ^[Yy]$ ]]; then
            echo -e "\n"
            "$BASE_DIR/Install.sh"
        else
            echo -e "\n\n${YELLOW}⛔ Installation cancelled.${RESET}"
            sleep 1.5
        fi
    fi
}

function list_services() {
    echo -e "${CYAN}List of Current Active Services:${RESET}"
    local found=false
    for file in "$CONFIG_DIR"/*.conf; do
        if [ -e "$file" ]; then
            basename "$file" .conf
            found=true
        fi
    done
    if ! $found; then
        echo -e "${YELLOW}(No services active)${RESET}"
    fi
    echo
    read -p "Press Enter to return..."
}

function add_service() {
    clear_and_header
    echo -e "${YELLOW}➕ Add a New Proxy Service:${RESET}\n"
    echo -e "  ${CYAN}[1]${RESET} spotify"
    echo -e "  ${CYAN}[2]${RESET} gemini"
    echo -e "  ${CYAN}[3]${RESET} discord"
    echo -e "  ${CYAN}[4]${RESET} youtube"
    echo -e "  ${CYAN}[5]${RESET} openai"
    echo -e "  ${CYAN}[6]${RESET} ✏️  [Type custom service name]"
    echo -e "  ${CYAN}[7]${RESET} 🔙 Back"
    echo
    
    local service_name=""
    read -n 1 -s choice
    case "$choice" in
        1) service_name="spotify" ;;
        2) service_name="google-gemini" ;; # Matches the exact V2Fly filename
        3) service_name="discord" ;;
        4) service_name="youtube" ;;
        5) service_name="openai" ;;
        6) 
            echo -ne "\n${YELLOW}Enter custom service name (e.g. netflix): ${RESET}"
            read -r service_name
            ;;
        7) return ;;
        *) echo -e "\n${RED}❌ Invalid option.${RESET}"; sleep 1; return ;;
    esac
    
    service_name=$(echo "$service_name" | tr '[:upper:]' '[:lower:]' | xargs)
    if [ -z "$service_name" ]; then
        echo -e "\n${RED}❌ Service name cannot be empty.${RESET}"
        sleep 1.2
        return
    fi
    
    echo -e "\n---"
    echo -e "${YELLOW}Select configuration method for '$service_name':${RESET}"
    echo -e "  ${CYAN}[1]${RESET} Automatic (Queries community database)"
    echo -e "  ${CYAN}[2]${RESET} Manual (Type your own root domain)"
    echo
    
    local method=""
    read -n 1 -s config_choice
    case "$config_choice" in
        1) method="auto" ;;
        2) method="manual" ;;
        *) echo -e "\n${RED}❌ Invalid option.${RESET}"; sleep 1.2; return ;;
    esac

    echo -e "\n"
    "$BASE_DIR/AddDomain.sh" "$service_name" "$method"
    echo
    read -p "Press Enter to return..."
}

function remove_service() {
    clear_and_header
    echo -e "${YELLOW}🗑️  Remove an Active Service:${RESET}\n"
    
    local selected_service=""
    if ! select_active_service; then
        echo
        read -p "Press Enter to return..."
        return
    fi
    
    local conf_file="$CONFIG_DIR/$selected_service.conf"
    local hosts_file="$HOSTS_DIR/$selected_service.hosts"

    echo -e "\n"
    if [ -f "$conf_file" ] || [ -f "$hosts_file" ]; then
        sudo rm -f "$conf_file" "$hosts_file"
        echo -e "${GREEN}✅ Successfully deleted '$selected_service'.${RESET}"
        sudo systemctl restart coredns
    else
        echo -e "${RED}❌ Configuration files for '$selected_service' not found.${RESET}"
    fi
    echo
    read -p "Press Enter to return..."
}

function view_config() {
    clear_and_header
    echo -e "${YELLOW}📝 View Configuration Files:${RESET}\n"
    
    local selected_service=""
    if ! select_active_service; then
        echo
        read -p "Press Enter to return..."
        return
    fi
    
    local conf_file="$CONFIG_DIR/$selected_service.conf"
    local hosts_file="$HOSTS_DIR/$selected_service.hosts"

    echo -e "\n"
    if [ -f "$hosts_file" ]; then
        echo -e "${CYAN}--- Reference list (/etc/unblocker/$selected_service.hosts) ---${RESET}"
        cat "$hosts_file"
        echo -e "${CYAN}-------------------------------------------------------------${RESET}"
    elif [ -f "$conf_file" ]; then
        echo -e "${CYAN}--- CoreDNS Block (/etc/coredns/conf.d/$selected_service.conf) ---${RESET}"
        cat "$conf_file"
        echo -e "${CYAN}-------------------------------------------------------------${RESET}"
    else
        echo -e "${RED}❌ No files found for '$selected_service'.${RESET}"
    fi
    echo
    read -p "Press Enter to return..."
}

function main_menu() {
    while true; do
        clear_and_header
        service_status
        
        if [ -f "/usr/local/bin/coredns" ]; then
            echo -e "  ${CYAN}[1]${RESET} ${RED}❌ Uninstall DnsProxy${RESET}"
        else
            echo -e "  ${CYAN}[1]${RESET} ${GREEN}📥 Install DnsProxy${RESET}"
        fi
        
        echo -e "  ${CYAN}[2]${RESET} 📃 List active services"
        echo -e "  ${CYAN}[3]${RESET} ➕ Add a new service"
        echo -e "  ${CYAN}[4]${RESET} 🗑️  Remove a service"
        echo -e "  ${CYAN}[5]${RESET} 📝 View service configurations"
        echo -e "  ${CYAN}[6]${RESET} 🚪 Exit"
        echo
        
        read -n 1 -s choice
        case "$choice" in
            1) manage_installation ;;
            2) list_services ;;
            3) add_service ;;
            4) remove_service ;;
            5) view_config ;;
            6) clear; exit 0 ;;
            *) echo -e "${RED}Invalid selection.${RESET}"; sleep 0.8 ;;
        esac
    done
}

main_menu