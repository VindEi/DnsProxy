#!/bin/bash

#===[ Constants ]===
PROJECT_NAME="DnsProxy"
BASE_DIR="/usr/local/bin/DnsProxy"
CONFIG_DIR="/etc/coredns/conf.d"
HOSTS_DIR="/etc/unblocker"

#===[ Colors ]===
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
RESET='\033[0m'

#===[ CLI Mode Parameter Handling ]===
if [ "$#" -gt 0 ]; then
    case "$1" in
        "add")
            if [ -z "${2:-}" ] || [ -z "${3:-}" ]; then
                echo -e "${RED}❌ Usage: dnsproxy add <service_name> <auto|manual>${RESET}"
                exit 1
            fi
            "$BASE_DIR/AddDomain.sh" "$2" "$3"
            exit 0
            ;;
        "remove")
            if [ -z "${2:-}" ]; then
                echo -e "${RED}❌ Usage: dnsproxy remove <service_name>${RESET}"
                exit 1
            fi
            conf_file="$CONFIG_DIR/$2.conf"
            hosts_file="$HOSTS_DIR/$2.hosts"
            if [ -f "$conf_file" ] || [ -f "$hosts_file" ]; then
                sudo rm -f "$conf_file" "$hosts_file"
                sudo systemctl restart coredns
                echo -e "${GREEN}✅ Successfully removed '$2'.${RESET}"
            else
                echo -e "${RED}❌ Service '$2' not found.${RESET}"
            fi
            exit 0
            ;;
        *)
            echo -e "${YELLOW}Unknown command. Use 'dnsproxy' for the interactive dashboard.${RESET}"
            exit 1
            ;;
    esac
fi

#===[ Helpers ]===
function clear_and_header() {
    clear
    echo -e "${CYAN}╔══════════════════════════════╗"
    echo -e "║    🌐  DnsProxy Manager      ║"
    echo -e "╚══════════════════════════════╝${RESET}"
    echo
}

function service_status() {
    echo -e "${YELLOW}🔍 Service Status:${RESET}"
    systemctl is-active --quiet coredns && echo -e "🟢 CoreDNS: ${GREEN}Running${RESET}" || echo -e "🔴 CoreDNS: ${RED}Stopped${RESET}"
    systemctl is-active --quiet nginx && echo -e "🟢 NGINX: ${GREEN}Running${RESET}" || echo -e "🔴 NGINX: ${RED}Stopped${RESET}"
    
    local count=0
    if [ -d "$CONFIG_DIR" ]; then
        for file in "$CONFIG_DIR"/*.conf; do
            if [ -e "$file" ]; then
                ((count++))
            fi
        done
    fi
    echo -e "📂 Active Services: ${CYAN}${count}${RESET}"
    echo
}

# Unified Selector Helper: Scans active configs and displays them as a numbered list
function select_active_service() {
    local services=()
    local count=0
    
    # Populate array with active configuration names
    for file in "$CONFIG_DIR"/*.conf; do
        if [ -e "$file" ]; then
            local sname=$(basename "$file" .conf)
            services+=("$sname")
            ((count++))
        fi
    done
    
    if [ "$count" -eq 0 ]; then
        echo -e "${YELLOW}(No active services found)${RESET}"
        return 1
    fi
    
    echo -e "${CYAN}Select an active service from the list:${RESET}"
    for i in "${!services[@]}"; do
        echo -e "$((i+1))) ${services[$i]}"
    done
    echo -e "$((count+1))) 🔙 Back"
    echo
    
    while true; do
        read -p "Enter number: " sel
        if [[ "$sel" =~ ^[0-9]+$ ]] && [ "$sel" -ge 1 ] && [ "$sel" -le "$((count+1))" ]; then
            if [ "$sel" -eq "$((count+1))" ]; then
                return 1 # User chose Back
            fi
            selected_service="${services[$((sel-1))]}"
            return 0
        else
            echo -e "${RED}Invalid selection. Please try again.${RESET}"
        fi
    done
}

function manage_installation() {
    if [ -f "/usr/local/bin/coredns" ]; then
        echo -e "${RED}⚠️  WARNING: You are about to UNINSTALL DnsProxy.${RESET}"
        read -p "Are you sure you want to proceed with uninstallation? (y/N): " confirm
        if [[ "$confirm" =~ ^[Yy]$ ]]; then
            "$BASE_DIR/Uninstall.sh"
        else
            echo -e "\n${YELLOW}Uninstallation cancelled.${RESET}"
            sleep 1
        fi
    else
        echo -e "${GREEN}📥 You are about to INSTALL DnsProxy.${RESET}"
        read -p "Are you sure you want to proceed with installation? (y/N): " confirm
        if [[ "$confirm" =~ ^[Yy]$ ]]; then
            "$BASE_DIR/Install.sh"
        else
            echo -e "\n${YELLOW}Installation cancelled.${RESET}"
            sleep 1
        fi
    fi
}

function list_services() {
    echo -e "${CYAN}List of Current Active Services:${RESET}"
    local found=false
    for file in "$CONFIG_DIR"/*.conf; do
        if [ -e "$file" ]; then
            basename "$file" .conf
            found=true
        fi
    done
    if ! $found; then
        echo -e "${YELLOW}(No services active)${RESET}"
    fi
    echo
    read -p "Press enter to return..."
}

function add_service() {
    clear_and_header
    echo -e "${YELLOW}➕ Add a New Service:${RESET}"
    echo -e "1) spotify"
    echo -e "2) gemini"
    echo -e "3) discord"
    echo -e "4) youtube"
    echo -e "5) openai"
    echo -e "6) ✏️  [Type a custom service name]"
    echo -e "7) 🔙 Back"
    echo
    read -p "Choose an option: " add_choice
    
    local service_name=""
    case "$add_choice" in
        1) service_name="spotify" ;;
        2) service_name="gemini" ;;
        3) service_name="discord" ;;
        4) service_name="youtube" ;;
        5) service_name="openai" ;;
        6) 
            echo -ne "${YELLOW}Enter custom service name (e.g. netflix): ${RESET}"
            read service_name
            ;;
        7) return ;;
        *) echo -e "${RED}Invalid option.${RESET}"; sleep 1; return ;;
    esac
    
    service_name=$(echo "$service_name" | tr '[:upper:]' '[:lower:]' | xargs)
    if [ -z "$service_name" ]; then
        echo -e "${RED}Service name cannot be empty.${RESET}"
        sleep 1
        return
    fi
    
    echo -e "---"
    echo -e "${YELLOW}Select a configuration method for '$service_name':${RESET}"
    echo -e "1) Automatic"
    echo -e "2) Manual"
    read -p "Enter your choice (1 or 2): " config_choice

    case "$config_choice" in
        1) method="auto" ;;
        2) method="manual" ;;
        *) echo -e "${RED}Invalid choice. Returning to menu.${RESET}"; sleep 1; return ;;
    esac

    "$BASE_DIR/AddDomain.sh" "$service_name" "$method"
    read -p "Press enter to return..."
}

function remove_service() {
    clear_and_header
    echo -e "${YELLOW}🗑️  Remove a Service:${RESET}"
    
    local selected_service=""
    if ! select_active_service; then
        read -p "Press enter to return..."
        return
    fi
    
    local conf_file="$CONFIG_DIR/$selected_service.conf"
    local hosts_file="$HOSTS_DIR/$selected_service.hosts"

    if [ -f "$conf_file" ] || [ -f "$hosts_file" ]; then
        sudo rm -f "$conf_file" "$hosts_file"
        echo -e "${GREEN}✅ Removed configuration files for '$selected_service'${RESET}"
        sudo systemctl restart coredns
        echo -e "${CYAN}CoreDNS service restarted.${RESET}"
    else
        echo -e "${RED}❌ No configuration found for '$selected_service'.${RESET}"
    fi
    read -p "Press enter to return..."
}

function view_config() {
    clear_and_header
    echo -e "${YELLOW}📝 View Configuration:${RESET}"
    
    local selected_service=""
    if ! select_active_service; then
        read -p "Press enter to return..."
        return
    fi
    
    local conf_file="$CONFIG_DIR/$selected_service.conf"
    local hosts_file="$HOSTS_DIR/$selected_service.hosts"

    if [ -f "$hosts_file" ]; then
        echo -e "${CYAN}--- Contents of $hosts_file ---${RESET}"
        cat "$hosts_file"
        echo -e "${CYAN}-------------------------------${RESET}"
    elif [ -f "$conf_file" ]; then
        echo -e "${CYAN}--- Contents of $conf_file (Manual Mode) ---${RESET}"
        cat "$conf_file"
        echo -e "${CYAN}-------------------------------${RESET}"
    else
        echo -e "${RED}❌ No configuration or hosts file found for '$selected_service'.${RESET}"
    fi
    read -p "Press enter to return..."
}

function main_menu() {
    while true; do
        clear_and_header
        service_status
        
        if [ -f "/usr/local/bin/coredns" ]; then
            echo -e "${YELLOW}1) ❌ Uninstall DnsProxy"
        else
            echo -e "${YELLOW}1) 📥 Install DnsProxy"
        fi
        
        echo -e "2) 📃 List active services"
        echo -e "3) ➕ Add a new service"
        echo -e "4) 🗑️  Remove a service"
        echo -e "5) 📝 View service configurations"
        echo -e "6) 🚪 Exit${RESET}"
        echo
        read -p "Choose an option: " choice
        case "$choice" in
            1) manage_installation ;;
            2) list_services ;;
            3) add_service ;;
            4) remove_service ;;
            5) view_config ;;
            6) exit 0 ;;
            *) echo -e "${RED}Invalid option.${RESET}"; sleep 1 ;;
        esac
    done
}

main_menu