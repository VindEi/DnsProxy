#!/bin/bash

#===[ Constants ]===
PROJECT_NAME="DnsProxy"
BASE_DIR="/usr/local/bin/DnsProxy"
CONFIG_DIR="/etc/coredns/conf.d"
HOSTS_DIR="/etc/unblocker"

#===[ Colors ]===
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
RESET='\033[0m'

#===[ CLI Mode Parameter Handling ]===
if [ "$#" -gt 0 ]; then
    case "$1" in
        "add")
            if [ -z "${2:-}" ] || [ -z "${3:-}" ]; then
                echo -e "${RED}❌ Usage: dnsproxy add <service_name> <auto|manual>${RESET}"
                exit 1
            fi
            "$BASE_DIR/AddDomain.sh" "$2" "$3"
            exit 0
            ;;
        "remove")
            if [ -z "${2:-}" ]; then
                echo -e "${RED}❌ Usage: dnsproxy remove <service_name>${RESET}"
                exit 1
            fi
            conf_file="$CONFIG_DIR/$2.conf"
            hosts_file="$HOSTS_DIR/$2.hosts"
            if [ -f "$conf_file" ] || [ -f "$hosts_file" ]; then
                sudo rm -f "$conf_file" "$hosts_file"
                sudo systemctl restart coredns
                echo -e "${GREEN}✅ Successfully removed '$2'.${RESET}"
            else
                echo -e "${RED}❌ Service '$2' not found.${RESET}"
            fi
            exit 0
            ;;
        *)
            echo -e "${YELLOW}Unknown command. Use 'dnsproxy' for the interactive dashboard.${RESET}"
            exit 1
            ;;
    esac
fi

#===[ Helpers ]===
function clear_and_header() {
    clear
    echo -e "${CYAN}╔══════════════════════════════╗"
    echo -e "║    🌐  DnsProxy Manager      ║"
    echo -e "╚══════════════════════════════╝${RESET}"
    echo
}

function service_status() {
    echo -e "${YELLOW}🔍 Service Status:${RESET}"
    systemctl is-active --quiet coredns && echo -e "🟢 CoreDNS: ${GREEN}Running${RESET}" || echo -e "🔴 CoreDNS: ${RED}Stopped${RESET}"
    systemctl is-active --quiet nginx && echo -e "🟢 NGINX: ${GREEN}Running${RESET}" || echo -e "🔴 NGINX: ${RED}Stopped${RESET}"
    
    local count=0
    if [ -d "$CONFIG_DIR" ]; then
        for file in "$CONFIG_DIR"/*.conf; do
            if [ -e "$file" ]; then
                ((count++))
            fi
        done
    fi
    echo -e "📂 Active Services: ${CYAN}${count}${RESET}"
    echo
}

function manage_installation() {
    if [ -f "/usr/local/bin/coredns" ]; then
        echo -e "${RED}⚠️  WARNING: You are about to UNINSTALL DnsProxy.${RESET}"
        read -p "Are you sure you want to proceed with uninstallation? (y/N): " confirm
        if [[ "$confirm" =~ ^[Yy]$ ]]; then
            "$BASE_DIR/Uninstall.sh"
        else
            echo -e "\n${YELLOW}Uninstallation cancelled.${RESET}"
            sleep 1
        fi
    else
        echo -e "${GREEN}📥 You are about to INSTALL DnsProxy.${RESET}"
        read -p "Are you sure you want to proceed with installation? (y/N): " confirm
        if [[ "$confirm" =~ ^[Yy]$ ]]; then
            "$BASE_DIR/Install.sh"
        else
            echo -e "\n${YELLOW}Installation cancelled.${RESET}"
            sleep 1
        fi
    fi
}

function list_services() {
    echo -e "${CYAN}List of Current Active Services:${RESET}"
    local found=false
    for file in "$CONFIG_DIR"/*.conf; do
        if [ -e "$file" ]; then
            basename "$file" .conf
            found=true
        fi
    done
    if ! $found; then
        echo -e "${YELLOW}(No services active)${RESET}"
    fi
    echo
    read -p "Press enter to return..."
}

function add_service() {
    echo -ne "${YELLOW}Enter the service name to add (e.g., spotify, gemini): ${RESET}"
    read service_name
    echo -e "---"
    echo -e "${YELLOW}Select a configuration method:${RESET}"
    echo -e "1) Automatic"
    echo -e "2) Manual"
    read -p "Enter your choice (1 or 2): " config_choice

    case "$config_choice" in
        1) method="auto" ;;
        2) method="manual" ;;
        *) echo -e "${RED}Invalid choice. Returning to menu.${RESET}"; sleep 1; return ;;
    esac

    "$BASE_DIR/AddDomain.sh" "$service_name" "$method"
    read -p "Press enter to return..."
}

function remove_service() {
    echo -ne "${YELLOW}Enter the service name to remove (e.g., gemini, spotify): ${RESET}"
    read service_name
    local conf_file="$CONFIG_DIR/$service_name.conf"
    local hosts_file="$HOSTS_DIR/$service_name.hosts"

    if [ -f "$conf_file" ] || [ -f "$hosts_file" ]; then
        sudo rm -f "$conf_file" "$hosts_file"
        echo -e "${GREEN}✅ Removed configuration files for '$service_name'${RESET}"
        sudo systemctl restart coredns
        echo -e "${CYAN}CoreDNS service restarted.${RESET}"
    else
        echo -e "${RED}❌ No configuration found for '$service_name'.${RESET}"
    fi
    read -p "Press enter to return..."
}

function view_config() {
    echo -ne "${YELLOW}Enter the service name to view (e.g., gemini, spotify): ${RESET}"
    read service_name
    local conf_file="$CONFIG_DIR/$service_name.conf"
    local hosts_file="$HOSTS_DIR/$service_name.hosts"

    if [ -f "$hosts_file" ]; then
        echo -e "${CYAN}--- Contents of $hosts_file ---${RESET}"
        cat "$hosts_file"
        echo -e "${CYAN}-------------------------------${RESET}"
    elif [ -f "$conf_file" ]; then
        echo -e "${CYAN}--- Contents of $conf_file (Manual Mode) ---${RESET}"
        cat "$conf_file"
        echo -e "${CYAN}-------------------------------${RESET}"
    else
        echo -e "${RED}❌ No configuration or hosts file found for '$service_name'.${RESET}"
    fi
    read -p "Press enter to return..."
}

function main_menu() {
    while true; do
        clear_and_header
        service_status
        
        # 1. Dynamic Installation toggle
        if [ -f "/usr/local/bin/coredns" ]; then
            echo -e "${YELLOW}1) ❌ Uninstall DnsProxy"
        else
            echo -e "${YELLOW}1) 📥 Install DnsProxy"
        fi
        
        # Flat, ergonomic structure
        echo -e "2) 📃 List active services"
        echo -e "3) ➕ Add a new service"
        echo -e "4) 🗑️  Remove a service"
        echo -e "5) 📝 View service configurations"
        echo -e "6) 🚪 Exit${RESET}"
        echo
        read -p "Choose an option: " choice
        case "$choice" in
            1) manage_installation ;;
            2) list_services ;;
            3) add_service ;;
            4) remove_service ;;
            5) view_config ;;
            6) exit 0 ;;
            *) echo -e "${RED}Invalid option.${RESET}"; sleep 1 ;;
        esac
    done
}

main_menu